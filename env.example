# Copiá a .env y completá los valores.

# Supabase → Project Settings → Database → Connection string → URI (Direct connection, puerto 5432).
# Reemplazá [YOUR-PASSWORD] por la contraseña de la base.
DATABASE_URL="postgresql://postgres:CONTRASENA@db.PROYECTO.supabase.co:5432/postgres?sslmode=require"

# Mínimo 32 caracteres, secreto y aleatorio (producción).
AUTH_SECRET="poné-aquí-un-secreto-largo-de-al-menos-32-caracteres"
